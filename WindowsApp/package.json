{
  "name": "lyricscaster-windows",
  "version": "1.1.0",
  "description": "LyricsCaster жӯҢиҜҚжҠ•еұҸ WindowsзүҲ",
  "author": "ManJoy",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrea23shannon-ship-it/manjoy.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "node ./node_modules/typescript/bin/tsc -p tsconfig.main.json",
    "build:renderer": "node ./node_modules/vite/bin/vite.js build",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build && node ./node_modules/electron-builder/out/cli/cli.js --win --publish never",
    "start": "electron dist/main/index.js"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "electron-store": "^8.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.lyricscaster.windows",
    "productName": "LyricsCaster",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LyricsCaster жӯҢиҜҚжҠ•еұҸ"
    },
    "files": [
      "dist/**/*"
    ]
  }
}
